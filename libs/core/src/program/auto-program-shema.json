{
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "title": "AutoProgram",
    "description": "Auto program schema",

    "$defs": {
        "AutoActionName": {
            "type": "string",
            "enum": ["AutoActionRoot", "AutoActionClick", "AutoActionCheckGroup", "AutoActionCheck", "AutoActionGetText", "AutoActionEnterText", "AutoActionWait", "AutoActionScrollIntoView", "AutoActionSelectFile", "AutoActionWaitUntil", "AutoActionSetValue", "AutoActionCase", "AutoActionDragNDrop", "AutoActionUrl", "AutoActionFocus", "AutoActionProcedure", "AutoActionEmpty", "AutoActionConsoleLog", "AutoActionGoTo", "AutoActionGroup", "AutoActionCaseParameter"]
        },
        "StringOrIQuerySelectorWithParameters": {
            "anyOf": [
                {"type": "string"},
                {"$ref": "#/$defs/QuerySelectorWithParameters"}
            ]
        },
        "StringOrIQuerySelector": {
            "anyOf": [
                {"type": "string"},
                {"$ref": "#/$defs/QuerySelector"}
            ]
        },
        "QuerySelectorWithPropertyLink": {
            "anyOf": [
                {"$ref": "#/$defs/ParameterLink"},
                {"$ref": "#/$defs/StringOrIQuerySelectorWithParameters"}
            ]
        },
        "AutoParameterValue": {
            "anyOf": [
                {"type": "string"},
                {"type": "number"},
                {"type": "boolean"},
                {"$ref": "#/$defs/QuerySelectorWithParameters"}
            ]
        },
        "AutoValueSourceType": {
            "anyOf": [
                {"const": "attribute"},
                {"const": "innerText"},
                {"const": "textContent"},
                {"const": "innerHTML"}
            ]
        },
        "ParameterLink": {
            "type": "object",
            "properties": {
                "type": {
                    "const": "ParameterLink"
                },
                "name": {
                    "type": "string"
                }
            },
            "required": [
                "type",
                "name"
            ]
        },
        "AutoParameter": {
            "type": "object",
            "properties": {
                "name": {
                    "type": "string"
                },
                "value": {
                    "$ref": "#/$defs/AutoParameterValue"
                }
            },
            "required": [
                "name",
                "value"
            ]
        },
        "QuerySelector": {
            "type": "object",
            "properties": {
                "selector": {
                    "type": "string"
                },
                "innerText": {
                    "type": "string"
                },
                "textContent": {
                    "type": "string"
                },
                "all": {
                    "type": "boolean"
                },
                "child": {
                    "anyOf": [
                        {"type": "string"},
                        {"$ref": "#/$defs/QuerySelector"}
                    ]
                },
                "parent": {
                    "anyOf": [
                        {"type": "string"},
                        {"$ref": "#/$defs/QuerySelector"}
                    ]
                },
                "iframe": {
                    "anyOf": [
                        {"type": "string"},
                        {"$ref": "#/$defs/QuerySelector"}
                    ]
                },
                "parentLevel": {
                    "type": "integer"
                }
            },
            "required": [
                "selector"
            ]
        },
        "AutoValue": {
            "type": "object",
            "properties": {
                "type": {
                    "const": "AutoValue"
                },
                "selector": {
                    "$ref": "#/$defs/QuerySelectorWithPropertyLink"
                },
                "wait": {
                    "type": "boolean"
                },
                "valueType": {
                    "$ref": "#/$defs/AutoValueSourceType"
                },
                "attributeName": {
                    "type": "string"
                }
            },
            "required": [
                "type",
                "selector",
                "wait",
                "valueType",
                "attributeName"
            ]
        },
        "QuerySelectorWithParameters": {
            "type": "object",
            "properties": {
                "selector": {
                    "anyOf": [
                        {"$ref": "#/$defs/StringOrIQuerySelector"},
                        {"$ref": "#/$defs/ParameterLink"}
                    ]
                },
                "innerText": {
                    "anyOf": [
                        {"type": "string"},
                        {"$ref": "#/$defs/ParameterLink"},
                        {"$ref": "#/$defs/AutoValue"}
                    ]
                },
                "textContent": {
                    "anyOf": [
                        {"type": "string"},
                        {"$ref": "#/$defs/ParameterLink"}
                    ]
                },
                "all": {
                    "anyOf": [
                        {"type": "string"},
                        {"$ref": "#/$defs/ParameterLink"}
                    ]
                },
                "child": {
                    "$ref": "#/$defs/StringOrIQuerySelectorWithParameters"
                },
                "parent": {
                    "$ref": "#/$defs/StringOrIQuerySelectorWithParameters"
                },
                "iframe": {
                    "$ref": "#/$defs/StringOrIQuerySelectorWithParameters"
                }
            },
            "required": [
                "selector"
            ]
        },
        "AutoProcedure": {
            "type": "object",
            "properties": {
                "name": {
                    "type": "string"
                },
                "description": {
                    "type": "string"
                },
                "action": {
                    "$ref": "#/$defs/AutoAction"
                }
            },
            "required": [
                "name",
                "description",
                "action"
            ]
        },
        "AutoAction": {
            "type": "object",
            "properties": {
                "id": {
                    "type": "string"
                },
                "name": {
                    "$ref": "#/$defs/AutoActionName"
                },
                "description": {
                    "type": "string"
                },
                "continueAfterFail": {
                    "type": "boolean"
                },
                "timeout": {
                    "type": "integer"
                },
                "children": {
                    "type": "array",
                    "items": {
                        "$ref": "#/$defs/AutoAction"
                    }
                },
                "parameters": {
                    "type": "array",
                    "items": {
                        "$ref": "#/$defs/AutoParameter"
                    }
                }
            },
            "required": [
                "name"
            ]
        },
        "AutoActionClick": {
            "type": "object",
            "allOf": [
                {
                    "$ref": "#/$defs/AutoAction"
                },
                {
                    "properties": {
                        "name": {
                            "const": "AutoActionClick"
                        },
                        "selector": {
                            "$ref": "#/$defs/QuerySelectorWithPropertyLink"
                        },
                        "smoothMouse": {
                            "type": "boolean"
                        },
                        "wait": {
                            "type": "boolean"
                        },
                        "clickType": {
                            "enum": ["MouseDownFocusMouseUp", "Click"]
                        }
                    },
                    "required": [
                        "name",
                        "selector",
                        "smoothMouse",
                        "wait",
                        "clickType"
                    ]
                }
            ]
        }
    },

    "type": "object",
    "properties": {
        "name": {
            "type": "string"
        },
        "description": {
            "type": "string"
        },
        "version": {
            "type": "integer"
        },
        "rootAction": {
            "oneOf": [
                {
                    "if": {
                        "properties": {
                            "name": {
                                "enum": ["AutoActionClick"]
                            }
                        }
                    },
                    "then": {
                        "$ref": "#/$defs/AutoActionClick"
                    },
                    "else": {
                        "$ref": "#/$defs/AutoAction"
                    }
                }
            ]
        },
        "procedures": {
            "type": "array",
            "items": {
                "$ref": "#/$defs/AutoProcedure"
            }
        }
    },
    "required": [
        "name",
        "description",
        "version",
        "rootAction",
        "procedures"
    ]
}
